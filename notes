	-- file map
    budget_tracker/
├── android/                  # Native Android specific code
│   └── app/src/main/kotlin/  # Where the SMS Listener lives (Kotlin)
├── lib/                      # Your Flutter code
│   ├── main.dart             # Entry point
│   ├── models/               # Expense object definitions
│   ├── services/             # SMS Parser & Database logic
│   ├── screens/              # UI (Dashboard, Reports)
│   └── widgets/              # Reusable UI components (Cards, Charts)
├── assets/                   # Icons and Fonts
└── pubspec.yaml              # Dependencies (sqflite, fl_chart)

